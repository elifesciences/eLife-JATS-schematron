<?oxygen SCHSchema="table-style-test-2.sch"?>
<!--Context: table
Test: report    descendant::*[name()=('tr','td','th') and @style[contains(.,'border')]]
Message:  contains some elements with border styling. Is this really necessary? -->
<root xmlns:ali="http://www.niso.org/schemas/ali/1.0/" xmlns:mml="http://www.w3.org/1998/Math/MathML" xmlns:xlink="http://www.w3.org/1999/xlink">
    <article>
        <table-wrap>
            <label>Test table 1.</label>
            <table>
                <thead>
                    <tr style="border-bottom: solid thin"/>
                </thead>
                <tbody>
                    <tr/>
                </tbody>
            </table>
        </table-wrap>
        <table-wrap>
            <label>Test table 2.</label>
            <table>
                <thead>
                    <tr><th style="border-bottom: solid thin"/></tr>
                </thead>
                <tbody>
                    <tr/>
                </tbody>
            </table>
        </table-wrap>
    </article>
</root>