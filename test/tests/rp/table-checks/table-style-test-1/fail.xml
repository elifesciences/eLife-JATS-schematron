<?oxygen SCHSchema="table-style-test-1.sch"?>
<!--Context: table
Test: report    descendant::*[name()=('tr','td','th') and @style[contains(.,'background-color')]]
Message:  contains some elements with background colour. Is this OK? -->
<root xmlns:ali="http://www.niso.org/schemas/ali/1.0/" xmlns:mml="http://www.w3.org/1998/Math/MathML" xmlns:xlink="http://www.w3.org/1999/xlink">
    <article>
        <table-wrap>
            <label>Test table 1.</label>
            <table>
                <thead>
                    <tr style="background-color:#F2F2F2"/>
                </thead>
                <tbody>
                    <tr/>
                </tbody>
            </table>
        </table-wrap>
        <table-wrap>
            <label>Test table 2.</label>
            <table>
                <thead>
                    <tr><th style="background-color:#F2F2F2"/></tr>
                </thead>
                <tbody>
                    <tr/>
                </tbody>
            </table>
        </table-wrap>
    </article>
</root>